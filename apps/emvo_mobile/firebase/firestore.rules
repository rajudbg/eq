rules_version = '2';

// Deploy from apps/emvo_mobile: `firebase deploy --only firestore:rules`
// Tighten as you add collections; this is the baseline before any writes ship.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
